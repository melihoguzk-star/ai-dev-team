      "x": 0,
      "y": 2
    },
    "category_card": {
      "color": "black",
      "opacity": 0.08,
      "radius": 6,
      "x": 0,
      "y": 2
    }
  },
  "images": {
    "product_grid_height": "160pt",
    "product_list_size": "90x90pt",
    "category_height": "120pt",
