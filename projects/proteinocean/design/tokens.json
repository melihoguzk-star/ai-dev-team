      "discount": "#FF3B30"
    }
  },
  "typography": {
    "price": { "font": "headline", "weight": "bold" },
    "product_name": { "font": "subheadline", "weight": "regular" },
    "category_name": { "font": "subheadline", "weight": "semibold" },
    "brand": { "font": "caption", "weight": "regular" },
    "badge": { "font": "caption2", "weight": "bold" },
    "count": { "font": "caption", "weight": "regular" }
  },
  "spacing": {
    "grid_gap": "12pt",
    "category_grid_gap": "16pt",
    "card_padding_grid": "10pt",
    "card_padding_list": "12pt",
