{
  "_note": "Bu token'lar mevcut implementasyondan çıkarılmıştır. brand-tokens.json (Faz 1.5) tamamlandığında primary/accent renkleri güncellenecektir.",
  "colors": {
    "primary": "#0000FF",
    "primary_note": "GEÇİCİ — brand-tokens.json'dan güncellenecek. Şu an system .blue kullanılıyor.",
    "background": {
